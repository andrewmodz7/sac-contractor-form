# Google service account credentials, as the FULL JSON object on a single line.
# Paste the entire contents of the service account key file here.
# Example: {"type":"service_account","project_id":"...","private_key":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Drive folder id of the master folder. This folder must contain a
# subfolder named "Active", which in turn contains one subfolder per property.
MASTER_FOLDER_ID=

# SendGrid API key used to send upload notification emails.
SENDGRID_API_KEY=

# Sender address for notification emails. Must be a verified sender or on an
# authenticated domain in SendGrid.
NOTIFY_FROM_EMAIL=