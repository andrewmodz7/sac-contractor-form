# Google service account credentials, as the FULL JSON object on a single line.
# Paste the entire contents of the service account key file here.
# Example: {"type":"service_account","project_id":"...","private_key":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Drive folder id of the master folder. This folder must contain a
# subfolder named "Active", which in turn contains one subfolder per property.
MASTER_FOLDER_ID=

# Gmail account used to send upload notification emails over SMTP. This is the
# full address (e.g. amodzelewski@shoreacrescapital.com) and also the From.
GMAIL_USER=amodzelewski@shoreacrescapital.com

# 16-character Gmail app password for GMAIL_USER (not the account password).
GMAIL_APP_PASSWORD=weynvowscotwqytj